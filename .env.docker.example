# OpenRouter (рекомендуется для текущей конфигурации)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_SITE_URL=http://localhost:18174
OPENROUTER_APP_NAME=MindVault

# Совместимость с OpenAI API (можно оставить пустым, если используете только OpenRouter)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Необязательно: глобальный стиль ответов ассистента.
# ASSISTANT_SYSTEM_PROMPT=Отвечай кратко, по делу, без длинных вступлений.
